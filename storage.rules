rules_version = '2';

// Cloud Storage rules for Port City Leash Club.
//
// Storage was enabled 2026-07-20; before that no bucket existed at all, so
// there were no rules to inherit. Everything is denied by default at the
// bottom — each path below has to opt in explicitly.
service firebase.storage {
  match /b/{bucket}/o {

    // NOTE: cross-service rules do NOT work here. An earlier version of this
    // file defined isAdmin()/isWalker() with
    // firestore.exists(/databases/(default)/documents/...), mirroring
    // firestore.rules. It compiled and deployed cleanly, then failed at
    // evaluation with "Function not found error: Name: [firestore.exists]" —
    // confirmed with the Rules test API, and firestore.get() is equally
    // unavailable. Every read and write was denied, including the admin's.
    // Do not reintroduce firestore.* here without testing evaluation, not
    // just compilation.
    //
    // Admin is therefore pinned to the one admin UID. There is exactly one
    // admins document today; if that changes, move to a custom auth claim
    // (request.auth.token.admin == true) rather than extending this list —
    // custom claims are verified to work here.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'SZNWwqHGPDYp8TOixmg1EOUZaBD2';
    }

    // Walk photos: a walker uploads one when completing a walk. Members see
    // their own dog's photo in the portal, so any signed-in user may read —
    // narrowing that to "the member on the walk" would need the walk doc's
    // memberId, which isn't in the storage path.
    //
    // contentType is checked here rather than trusting the client: the walker
    // app validates size only, and an `accept` attribute is a UI hint, not a
    // control.
    // Write is any signed-in user rather than specifically a walker, because
    // proving "is a walker" needs a Firestore lookup and cross-service rules
    // don't work here (see above). The signed-in population is admin, walkers
    // and members — so a member could in principle upload a walk photo. That's
    // bounded by the size and image-type checks, and walk photos aren't
    // sensitive. Tightening this properly means custom claims
    // (request.auth.token.walker == true), set when a walker account is created.
    match /walk-photos/{walkId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Resumes from careers.html. Applicants are NOT signed in — they're
    // strangers applying for a job — so create has to be open to
    // unauthenticated callers for the feature to work at all. That's
    // constrained to plausible resume files under 10MB.
    //
    // Read is admin-only and there is no list permission: an applicant can
    // add a file but can never read anyone's, including their own. These are
    // strangers' personal data and shouldn't be enumerable.
    match /resumes/{submissionId}/{fileName} {
      allow read: if isAdmin();
      allow create: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
             'application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document'
           );
      allow update, delete: if isAdmin();
    }

    // Anything not matched above is denied outright.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
