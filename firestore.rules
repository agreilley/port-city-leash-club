rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isWalker() {
      return request.auth != null && exists(/databases/$(database)/documents/walkers/$(request.auth.uid));
    }
    // Walkers are stored at two doc IDs: a friendly one (used as walks.walkerId)
    // and their Auth UID (used only for rule lookups, per admin/dashboard.html).
    // This resolves auth.uid -> the friendly walkerId used to scope walk access.
    function myWalkerId() {
      return get(/databases/$(database)/documents/walkers/$(request.auth.uid)).data.get('walkerId', request.auth.uid);
    }

    match /admins/{uid} {
      // Read-only to clients: a user may check whether their OWN uid is an
      // admin (that's what isAdmin() and the portal auth guards rely on), but
      // may never write here. Client write was a full privilege-escalation
      // hole — `uid == request.auth.uid` let ANY signed-in user create their
      // own admin doc and thereby pass isAdmin() everywhere (Firestore rules,
      // storage.rules, and assertIsAdmin() in every privileged Cloud Function).
      // Admin membership is now managed out-of-band only (Firebase console, or
      // a future custom auth claim — storage.rules notes claims work there).
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /members/{id} {
      allow read, write: if isAdmin();
      allow read: if isWalker();
      allow read: if request.auth != null && request.auth.uid == id;

      // Allowlist, not denylist: a member may change ONLY these self-service
      // profile fields on their own doc. The previous rule denied a fixed set
      // of Stripe keys and allowed everything else, which left billing-adjacent
      // fields member-writable — e.g. writing currentMonthCharge:{status:'charged'}
      // to dodge the mid-month charge (chargeCurrentMonthWalks idempotency guard),
      // changing `tier` to alter the per-walk price, or writing
      // status/pauseStartDate/pauseEndDate/membershipStartDate directly to bypass
      // the validated submitVacationHold flow. Anything not listed here (tier,
      // billing state, membership status, walk schedule, assigned walker) is now
      // rejected and can only change via admin or a Cloud Function.
      // Fields written by the two self-service portal pages that touch the
      // member doc directly: portal-account.html (name/phone/address) and
      // portal-pet-profile.html (dogs + the denormalized dogName/petBreed and
      // the home-access fields). All are non-billing profile/access data.
      // emergencyContact is included for a planned profile field; harmless if
      // unused. Deliberately EXCLUDED (admin- or Cloud-Function-only): tier,
      // status, billingStatus, currentMonthCharge, membershipStartDate,
      // pauseStartDate, pauseEndDate, defaultWalkDays, assignedWalkerId, and
      // every stripe* key.
      allow update: if request.auth != null
        && request.auth.uid == id
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'name',
                'phone',
                'address',
                'dogs',
                'dogName',
                'petBreed',
                'parkingNotes',
                'entryCode',
                'accessNotes',
                'emergencyContact'
              ]);

      // ── Billing (M-1) ──────────────────────────────────────────────────
      // The five sensitive billing fields live HERE, in a subcollection, not
      // on the parent member doc — so the open `allow read: if isWalker()`
      // above can never expose them. Firestore subcollection rules do NOT
      // inherit the parent match's allows (rules never cascade without a
      // {document=**} wildcard, and none exists in this file), so a walker
      // gets nothing under /private. Holds: stripeCustomerId,
      // stripeSubscriptionId, stripeSubscriptionItemId, billingStatus,
      // currentMonthCharge. Written ONLY by Cloud Functions (admin SDK
      // bypasses rules); a member may read their OWN copy for card-on-file.
      //
      // FOOTGUN WARNING: the {doc} wildcard means the member can read ANY doc
      // under their own /private — not just `billing`. Do NOT store
      // member-hidden data here expecting it to be admin-only; anything a
      // member must never see needs a different location (or an owner-excluding
      // rule). Today only `billing` lives here, and the member is allowed to
      // read it.
      match /private/{doc} {
        allow read: if isAdmin()
          || (request.auth != null && request.auth.uid == id);
        allow write: if false;
      }
    }

    match /walkers/{id} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /walks/{id} {
      allow read, write: if isAdmin();

      allow read, update: if isWalker() && resource.data.walkerId == myWalkerId();

      allow read: if request.auth != null && resource.data.memberId == request.auth.uid;

      // Members may flag their own walk for a 45-minute extension
      // (portal-extend-walk.html) — the actual charge/confirmation happens
      // via admin review (confirmWalkExtension() in admin/dashboard.html,
      // which sets extendedStatus to 'confirmed' or resets it to null).
      // hasOnly() only limits which fields change, not their values, so
      // the values are pinned here too — otherwise a member could write
      // extendedStatus: 'confirmed' directly and skip the review/charge.
      allow update: if request.auth != null
        && resource.data.memberId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['extended', 'extendedStatus', 'duration'])
        && request.resource.data.extended == true
        && request.resource.data.extendedStatus == 'pending'
        && request.resource.data.duration == '45-minute walk';
    }

    match /submissions/{id} {
      allow read, write: if isAdmin();

      // ── Public create hardening (M-2) ──────────────────────────────────
      // The four public lead-gen forms submit before the visitor has an
      // account, so they can't be gated behind request.auth != null. The old
      // rule accepted the anonymous branch on `type` alone — arbitrary fields,
      // arbitrary types, arbitrary size. That let an anonymous writer spoof
      // sensitive fields (memberId, estimatedTotal, stripeCustomerId, …) and
      // send giant payloads, and every create fires onNewSubmission (function
      // invocation + a possible Gmail send when meetGreetDateTime parses).
      //
      // SCOPE: only the ANONYMOUS branch is constrained here. The
      // request.auth != null branch stays permissive — authenticated portal /
      // member / walker submissions cover ~8 other types (reschedule,
      // dog_update, pause_membership, tier_change, overnight_request,
      // walker_incident, walker_schedule_request, vacation_hold_refund) with
      // their own shapes, and M-2 is the unauthenticated vector. Tightening
      // that branch would risk breaking those forms for no in-scope benefit.
      //
      // Each validator is a strict hasOnly() allowlist derived from the exact
      // client payload of one form. hasOnly() rejects any field not listed —
      // so memberId / stripeCustomerId / paymentMethodStatus / billingStatus /
      // tier / currentMonthCharge are all rejected automatically (the Stripe
      // fields are written server-side by createSetupIntent via the admin SDK
      // AFTER create, so rejecting them here does not break card-on-file).
      //
      // FIELD-DRIFT WARNING: these allowlists mirror the current form payloads.
      // If a form's fields change, update the matching validator in lockstep or
      // that form's submissions will start being rejected. Each validator names
      // its source form + line.
      //
      // SIZE CAPS: the four forms carry NO maxlength attributes (verified), so
      // these .size() caps are the ONLY length enforcement. They are set well
      // above any realistic human input (free-text up to 10k chars) so a
      // legitimate max-length submission can never hit them; the real backstop
      // is Firestore's 1 MB document limit.

      // Shared by all four public types: system fields + email (all four write
      // a string email, possibly '').
      function subBase() {
        return request.resource.data.read == false
          && request.resource.data.createdAt is timestamp
          && request.resource.data.type is string
          && request.resource.data.email is string
          && request.resource.data.email.size() <= 320;
      }

      // Source: contact.html:224 (submitContact)
      function validContact() {
        return request.resource.data.keys().hasOnly(
            ['type', 'name', 'email', 'topic', 'message', 'read', 'createdAt'])
          && request.resource.data.name is string && request.resource.data.name.size() <= 200
          && request.resource.data.topic is string && request.resource.data.topic.size() <= 100
          && request.resource.data.message is string && request.resource.data.message.size() <= 10000;
      }

      // Source: membership-request.html:551 (membershipForm submit).
      // startDate is localDateToTimestamp() → timestamp OR null (empty input),
      // so it must be null-tolerant. dogs is collectDogs() → list of maps with
      // variable per-species keys; type-checked as a list and size-capped only.
      function validMembership() {
        return request.resource.data.keys().hasOnly(
            ['type', 'plan', 'ownerName', 'email', 'phone', 'address', 'accessNotes',
             'dogs', 'dogName', 'startDate', 'timeWindow', 'days', 'meetGreetDateTime',
             'read', 'createdAt'])
          && request.resource.data.ownerName is string && request.resource.data.ownerName.size() <= 200
          && request.resource.data.phone is string && request.resource.data.phone.size() <= 50
          && request.resource.data.address is string && request.resource.data.address.size() <= 1000
          && request.resource.data.accessNotes is string && request.resource.data.accessNotes.size() <= 5000
          && request.resource.data.plan is string && request.resource.data.plan.size() <= 100
          && request.resource.data.timeWindow is string && request.resource.data.timeWindow.size() <= 100
          && request.resource.data.days is string && request.resource.data.days.size() <= 200
          && request.resource.data.dogName is string && request.resource.data.dogName.size() <= 200
          && request.resource.data.meetGreetDateTime is string && request.resource.data.meetGreetDateTime.size() <= 100
          && (request.resource.data.startDate == null || request.resource.data.startDate is timestamp)
          && request.resource.data.dogs is list && request.resource.data.dogs.size() <= 10;
      }

      // Source: service-request.html:700 (serviceForm submit).
      // startDate AND endDate are both localDateToTimestamp() → timestamp OR
      // null; a one-time service legitimately has endDate: null, so both must
      // be null-tolerant. estimatedTotal is a client-computed DISPLAY estimate
      // (grandTotal), not the authoritative charge — the real charge is
      // computed server-side in chargeSavedCard — so it's allowed but pinned to
      // a non-negative capped number.
      function validService() {
        return request.resource.data.keys().hasOnly(
            ['type', 'service', 'startDate', 'endDate', 'visitsPerDay', 'extraPet',
             'medication', 'dogs', 'ownerName', 'email', 'phone', 'address',
             'meetGreetDateTime', 'estimatedTotal', 'read', 'createdAt'])
          && request.resource.data.ownerName is string && request.resource.data.ownerName.size() <= 200
          && request.resource.data.phone is string && request.resource.data.phone.size() <= 50
          && request.resource.data.address is string && request.resource.data.address.size() <= 1000
          // 'service' is a reserved word in the rules language (`service
          // cloud.firestore`), so this field MUST be read via bracket access —
          // dot access (request.resource.data.service) fails to compile.
          && request.resource.data['service'] is string && request.resource.data['service'].size() <= 100
          && request.resource.data.visitsPerDay is string && request.resource.data.visitsPerDay.size() <= 50
          && request.resource.data.meetGreetDateTime is string && request.resource.data.meetGreetDateTime.size() <= 100
          && request.resource.data.extraPet is bool
          && request.resource.data.medication is bool
          && request.resource.data.estimatedTotal is number
          && request.resource.data.estimatedTotal >= 0
          && request.resource.data.estimatedTotal <= 100000
          && (request.resource.data.startDate == null || request.resource.data.startDate is timestamp)
          && (request.resource.data.endDate == null || request.resource.data.endDate is timestamp)
          && request.resource.data.dogs is list && request.resource.data.dogs.size() <= 10;
      }

      // Source: careers.html:361 (submitApplication) + :442 resume spread.
      // resumePath / resumeName are OPTIONAL (present only when a resume is
      // attached) — hasOnly() permits their absence, and each is guarded with
      // an `in` check before size validation. availability is a map
      // ({mon:[...], ...}). experience / days are comma-joined strings.
      function validApplication() {
        return request.resource.data.keys().hasOnly(
            ['type', 'name', 'email', 'phone', 'neighborhood', 'dogExperience',
             'experience', 'availability', 'walksPerWeek', 'transportation',
             'additional', 'read', 'createdAt', 'resumePath', 'resumeName'])
          && request.resource.data.name is string && request.resource.data.name.size() <= 200
          && request.resource.data.phone is string && request.resource.data.phone.size() <= 50
          && request.resource.data.neighborhood is string && request.resource.data.neighborhood.size() <= 200
          && request.resource.data.dogExperience is string && request.resource.data.dogExperience.size() <= 10000
          && request.resource.data.experience is string && request.resource.data.experience.size() <= 500
          && request.resource.data.walksPerWeek is string && request.resource.data.walksPerWeek.size() <= 50
          && request.resource.data.transportation is string && request.resource.data.transportation.size() <= 100
          && request.resource.data.additional is string && request.resource.data.additional.size() <= 10000
          && request.resource.data.availability is map
          && (!('resumePath' in request.resource.data)
              || (request.resource.data.resumePath is string && request.resource.data.resumePath.size() <= 500))
          && (!('resumeName' in request.resource.data)
              || (request.resource.data.resumeName is string && request.resource.data.resumeName.size() <= 500));
      }

      allow create: if request.auth != null
        || (subBase() && (
              (request.resource.data.type == 'contact' && validContact())
           || (request.resource.data.type == 'membership_request' && validMembership())
           || (request.resource.data.type == 'service_request' && validService())
           || (request.resource.data.type == 'application' && validApplication())
        ));

      allow read: if request.auth != null && resource.data.memberId == request.auth.uid;
    }

    match /meet_greet_availability/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /overnights/{id} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && resource.data.memberId == request.auth.uid;

      // Same shape as the walks walker-scoping rule — unrestricted field
      // access on their own assigned overnight, matching how completeWalk()
      // already writes multiple fields freely on walks.
      allow read, update: if isWalker() && resource.data.walkerId == myWalkerId();
    }

    match /conversations/{id} {
      allow read, write: if isAdmin();
      match /messages/{messageId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
